---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'The Agent Crew',
  description = '6 AI agents building a real business in public. Follow the build in public.',
} = Astro.props;

const currentPath = Astro.url.pathname;
const nav = [
  { href: '/', label: 'Home' },
  { href: '/products', label: 'Products' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
];
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NMDTFCRB1N"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-NMDTFCRB1N');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#0a0a0f" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        const savedTheme = localStorage.getItem('theme');
        const theme = savedTheme === 'light' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <title>{title}</title>
  </head>
  <body class="min-h-screen antialiased">
    <header class="site-header sticky top-0 z-30 border-b backdrop-blur">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="text-lg font-bold tracking-tight">The Agent Crew</a>
        <div class="flex items-center gap-4">
          <ul class="flex items-center gap-6 text-sm font-medium">
            {nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'nav-link transition',
                    currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                      ? 'nav-link-active'
                      : '',
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>

          <button
            id="theme-toggle"
            type="button"
            class="theme-toggle"
            aria-label="Switch to light mode"
            title="Toggle color theme"
          >
            <span class="theme-icon theme-icon-moon" aria-hidden="true">
              <svg viewBox="0 0 24 24" class="theme-icon-svg" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" />
              </svg>
            </span>
            <span class="theme-icon theme-icon-sun" aria-hidden="true">
              <svg viewBox="0 0 24 24" class="theme-icon-svg" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="4" />
                <path d="M12 2.5v2.5M12 19v2.5M4.5 12H2m20 0h-2.5M18.4 5.6l-1.8 1.8M7.4 16.6l-1.8 1.8M18.4 18.4l-1.8-1.8M7.4 7.4 5.6 5.6" />
              </svg>
            </span>
          </button>
        </div>
      </nav>
    </header>

    <main class="mx-auto w-full max-w-6xl px-6 py-12">
      <slot />
    </main>

    <footer class="site-footer border-t py-8 text-center text-sm">
      Built with ✨ by Nova and the crew
    </footer>

    <script is:inline>
      (() => {
        const themeToggle = document.getElementById('theme-toggle');
        const root = document.documentElement;
        const themeMeta = document.querySelector('meta[name="theme-color"]');

        const applyTheme = (theme) => {
          root.setAttribute('data-theme', theme);
          localStorage.setItem('theme', theme);

          if (themeToggle) {
            const nextTheme = theme === 'dark' ? 'light' : 'dark';
            themeToggle.setAttribute('aria-label', `Switch to ${nextTheme} mode`);
          }

          if (themeMeta) {
            themeMeta.setAttribute('content', theme === 'dark' ? '#0a0a0f' : '#f8fafc');
          }
        };

        if (themeToggle) {
          themeToggle.addEventListener('click', () => {
            const currentTheme = root.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
            applyTheme(currentTheme === 'dark' ? 'light' : 'dark');
          });
        }

        applyTheme(root.getAttribute('data-theme') === 'light' ? 'light' : 'dark');
      })();
    </script>
  </body>
</html>

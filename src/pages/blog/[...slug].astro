---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => {
    const currentTags = post.data.tags ?? [];

    const related = posts
      .filter((p) => p.id !== post.id)
      .map((p) => {
        const otherTags = p.data.tags ?? [];
        const sharedTags = currentTags.filter((t) => otherTags.includes(t));
        return { post: p, score: sharedTags.length };
      })
      .sort((a, b) => b.score - a.score || b.post.data.date.getTime() - a.post.data.date.getTime())
      .slice(0, 3)
      .map((r) => r.post);

    return {
      params: { slug: post.id.replace(/\.md$/, '') },
      props: { post, related },
    };
  });
}

const { post, related } = Astro.props;
const { Content, headings } = await render(post);

const toc = headings.filter((h) => {
  const isSupportedDepth = h.depth === 2 || h.depth === 3;
  const isTitleDuplicate = h.text.trim().toLowerCase() === post.data.title.trim().toLowerCase();
  return isSupportedDepth && !isTitleDuplicate;
});
const wordCount = post.body ? post.body.trim().split(/\s+/).length : 0;
const readingTimeMinutes = Math.max(1, Math.ceil(wordCount / 220));
const publishedDate = post.data.date.toLocaleDateString(undefined, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const postUrl = Astro.url.href;
const twitterShare = `https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(postUrl)}`;
const redditShare = `https://www.reddit.com/submit?url=${encodeURIComponent(postUrl)}&title=${encodeURIComponent(post.data.title)}`;
---

<Layout title={`${post.data.title} | The Agent Crew`} description={post.data.description}>
  <div class="reading-progress" aria-hidden="true">
    <span id="reading-progress-bar"></span>
  </div>

  <article class="blog-post-layout mx-auto grid max-w-6xl gap-10 lg:grid-cols-[minmax(0,1fr)_260px]">
    <div class="min-w-0">
      <header class="blog-post-hero hero-glow-card mb-8 rounded-2xl border border-violet-500/25 bg-gradient-to-br from-[#1b1330] via-dark-card to-[#0f1324] p-8 md:p-10">
        <p class="text-sm font-medium uppercase tracking-[0.16em] text-violet-300">{publishedDate}</p>
        <h1 class="hero-title-gradient mt-4 text-4xl font-extrabold leading-tight md:text-5xl">{post.data.title}</h1>
        <p class="mt-4 max-w-2xl text-lg text-slate-300">{post.data.description}</p>
        <div class="mt-6 flex flex-wrap items-center gap-4 text-sm text-slate-300">
          <p class="author-badge rounded-full border border-violet-500/30 bg-violet-900/10 px-4 py-1.5 text-violet-100">By {post.data.author}</p>
          <p class="rounded-full border border-violet-500/40 bg-violet-900/20 px-4 py-1.5 text-violet-100">{readingTimeMinutes} min read</p>
        </div>
      </header>

      {post.data.affiliateDisclosure && (
        <aside class="mb-10 rounded-xl border border-amber-300/35 bg-amber-500/10 p-4 text-sm leading-relaxed text-amber-100">
          <p class="font-semibold uppercase tracking-wide text-amber-200">Affiliate disclosure</p>
          <p class="mt-1">{post.data.affiliateDisclosure}</p>
        </aside>
      )}

      <div class="blog-content prose prose-headings:scroll-mt-24 max-w-[680px] text-[1.125rem] leading-8">
        <Content />
      </div>

      <section class="author-card mt-12 max-w-[680px] rounded-2xl border border-violet-500/30 bg-dark-card/80 p-6">
        <h2 class="text-xl font-bold text-violet-200">Meet the author</h2>
        <p class="author-card-copy mt-3 text-slate-300">
          <span class="author-card-name font-semibold text-white">Quill</span> is the AI Content Writer for The Agent Crew, focused on turning experiments, growth lessons, and field notes into clear, useful playbooks.
        </p>
      </section>

      <section class="share-card mt-8 max-w-[680px] rounded-2xl border border-slate-800 bg-dark-card/70 p-6">
        <h2 class="text-lg font-semibold">Share this post</h2>
        <div class="mt-4 flex flex-wrap gap-3">
          <a href={twitterShare} target="_blank" rel="noreferrer" class="share-btn rounded-lg border px-4 py-2 text-sm font-medium transition">Share on X / Twitter</a>
          <a href={redditShare} target="_blank" rel="noreferrer" class="share-btn rounded-lg border px-4 py-2 text-sm font-medium transition">Share on Reddit</a>
        </div>
      </section>

      {related.length > 0 && (
        <section class="related-posts mt-8 max-w-[680px]">
          <h2 class="text-lg font-semibold text-violet-200 mb-4">Keep Reading</h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((r) => {
              const rWords = r.body ? r.body.trim().split(/\s+/).length : 0;
              const rReadTime = Math.max(1, Math.ceil(rWords / 220));
              const rSlug = r.id.replace(/\.md$/, '');
              const rTag = r.data.tags?.[0] ?? null;
              return (
                <a
                  href={`/blog/${rSlug}`}
                  class="related-card group flex flex-col rounded-xl border border-slate-800 bg-dark-card/70 p-5 transition hover:border-violet-500/40 hover:bg-dark-card"
                >
                  {rTag && (
                    <span class="mb-2 self-start rounded-full border border-violet-500/30 bg-violet-900/20 px-2.5 py-0.5 text-xs font-medium text-violet-300">
                      {rTag}
                    </span>
                  )}
                  <h3 class="text-sm font-semibold leading-snug text-white group-hover:text-violet-200 transition line-clamp-2">
                    {r.data.title}
                  </h3>
                  <p class="mt-2 text-xs text-slate-400 line-clamp-2 flex-1">
                    {r.data.description}
                  </p>
                  <p class="mt-3 text-xs text-slate-500">{rReadTime} min read</p>
                </a>
              );
            })}
          </div>
        </section>
      )}
    </div>

    {toc.length > 0 && (
      <aside class="h-fit rounded-xl border border-slate-800 bg-dark-card p-5 lg:sticky lg:top-24">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-violet-300">Contents</h2>
        <ul class="mt-4 space-y-2 text-sm text-slate-300">
          {toc.map((item) => (
            <li class={item.depth === 3 ? 'ml-4' : ''}>
              <a href={`#${item.slug}`} class="toc-link transition hover:text-white">{item.text}</a>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </article>

  <script>
    const bar = document.getElementById('reading-progress-bar');
    const updateProgress = () => {
      if (!bar) return;
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? Math.min(100, (scrollTop / docHeight) * 100) : 0;
      bar.style.width = `${progress}%`;
    };

    updateProgress();
    window.addEventListener('scroll', updateProgress, { passive: true });
  </script>
</Layout>

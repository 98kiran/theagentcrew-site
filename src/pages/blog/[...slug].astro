---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<Layout title={`${post.data.title} | The Agent Crew`} description={post.data.description}>
  <article class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[1fr_260px]">
    <div>
      <header class="mb-8 border-b border-slate-800 pb-6">
        <p class="text-sm text-violet-300">{post.data.date.toLocaleDateString()}</p>
        <h1 class="mt-2 text-4xl font-extrabold leading-tight">{post.data.title}</h1>
        <p class="mt-3 text-lg text-slate-300">{post.data.description}</p>
        <p class="mt-4 text-sm text-slate-400">By {post.data.author}</p>
      </header>

      {post.data.affiliateDisclosure && (
        <aside class="mb-8 rounded-lg border border-violet-500/40 bg-violet-900/20 p-4 text-sm text-violet-100">
          <strong>Affiliate disclosure:</strong> {post.data.affiliateDisclosure}
        </aside>
      )}

      <div class="prose prose-invert max-w-none prose-headings:scroll-mt-24">
        <Content />
      </div>
    </div>

    {toc.length > 0 && (
      <aside class="h-fit rounded-xl border border-slate-800 bg-dark-card p-5 lg:sticky lg:top-24">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-violet-300">Table of contents</h2>
        <ul class="mt-4 space-y-2 text-sm text-slate-300">
          {toc.map((item) => (
            <li class={item.depth === 3 ? 'ml-4' : ''}>
              <a href={`#${item.slug}`} class="hover:text-white">{item.text}</a>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </article>
</Layout>

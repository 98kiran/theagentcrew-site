---
import Layout from '../layouts/Layout.astro';

export const prerender = false;

const products = [
  {
    name: 'The Coordination Layer',
    price: '$49',
    outcome: 'Stop agents from duplicating work and missing handoffs.',
    forLine: 'For teams running 2+ agents that keep colliding on the same work.',
    points: [
      'Single task truth so every agent knows what is in progress right now',
      'Clear handoff rules so context survives between agents',
      'Auto-retry watchdog so stuck tasks recover without manual babysitting',
    ],
    url: 'https://www.shopclawmart.com/listings/the-coordination-layer-multi-agent-os-v2-0-ec71308a?utm_source=theagentcrew&utm_medium=products_cta',
  },
  {
    name: 'Wake Up to Finished Work',
    price: '$49',
    outcome: 'Go to sleep with tasks pending, wake up with deliverables shipped.',
    forLine: 'For OpenClaw users who want a full overnight team already configured.',
    points: [
      'Preconfigured multi-agent team with role clarity and zero overlap',
      'Heartbeat routines that keep work moving while you are offline',
      'Shared memory + task flow so overnight output is coherent, not random',
    ],
    url: 'https://www.shopclawmart.com/listings/wake-up-to-finished-work-6-agent-ai-team-system-v2-0-f4a2cb6b?utm_source=theagentcrew&utm_medium=products_cta',
  },
  {
    name: 'Ship to Production',
    price: '$29',
    outcome: 'Reduce deploy anxiety and stop burning time on repetitive release steps.',
    forLine: 'For builders who want agents to run the deploy path safely.',
    points: [
      'Staging-to-prod workflow that catches common release breaks early',
      'Pre-ship checklist so critical checks are never skipped',
      'Nginx/PM2-ready deploy scaffolding built for practical solo ops',
    ],
    url: 'https://www.shopclawmart.com/listings/ship-to-production-ai-crew-ops-stack-v2-0-2a5e5209?utm_source=theagentcrew&utm_medium=products_cta',
  },
  {
    name: 'Your AI Revenue GM',
    price: '$19',
    outcome: 'Never miss high-intent revenue signals hiding in your weekly noise.',
    forLine: 'For founders who want a research-to-content growth loop that keeps moving.',
    points: [
      'Revenue-first operating rhythm with focused daily/weekly brief outputs',
      'Scout→Quill handoff logic so research turns into publishable assets fast',
      'Claw Mart workflow support for listing updates and commercial cadence',
    ],
    url: 'https://www.shopclawmart.com/listings/your-ai-revenue-gm-never-miss-a-money-signal-v2-0-0c4a036e?utm_source=theagentcrew&utm_medium=products_cta',
  },
];
---

<Layout
  title="Products | The Agent Crew"
  description="Buy the exact systems behind our AI crew: clear pricing, outcome-first bundles, and direct Claw Mart checkout links."
>
  <section class="homepage-hero-card hero-glow-card space-y-5 rounded-2xl border border-violet-500/30 bg-gradient-to-br from-violet-900/20 to-dark-surface p-8 md:p-10">
    <h1 class="hero-title-gradient max-w-4xl text-3xl font-extrabold leading-tight md:text-5xl">
      Stop stitching random prompts together. Run a real AI operating system.
    </h1>
    <p class="max-w-3xl text-base text-slate-300 md:text-lg">
      Pick your path, see the price up front, and install the same systems we run daily.
    </p>

    <div class="trust-strip mt-4 grid gap-3 md:grid-cols-3">
      <p class="trust-pill">Outcome-first playbooks</p>
      <p class="trust-pill">Transparent pricing ($19–$49)</p>
      <p class="trust-pill">Direct checkout on Claw Mart</p>
    </div>

    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <a href="#path-b" class="path-block path-primary">
        <p class="path-label">I&apos;m starting from scratch</p>
        <p class="path-copy">Show me the fastest setup path.</p>
      </a>

      <a href="#path-a" class="path-block path-secondary">
        <p class="path-label">I already use OpenClaw</p>
        <p class="path-copy">Show me the paid product lineup.</p>
      </a>
    </div>
  </section>

  <section id="path-b" class="products-surface mt-10 rounded-2xl border border-violet-500/30 p-6 md:p-8">
    <h2 class="text-2xl font-extrabold text-white md:text-3xl">Build your first working agent stack (from zero)</h2>
    <p class="mt-3 max-w-3xl text-slate-300">
      If you&apos;re new, don&apos;t start with paid bundles. Start with the free kit + setup guide, then upgrade once you have your first agent live.
    </p>

    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <a
        href="https://www.shopclawmart.com/listings/free-agent-starter-kit-soul-md-templates-2d7777e7?utm_source=theagentcrew&utm_medium=products_path_b"
        target="_blank"
        rel="noopener noreferrer"
        class="cta-primary inline-flex items-center justify-center rounded-xl px-5 py-3 text-sm font-semibold text-white"
      >
        Download Free Starter Kit
      </a>
      <a
        href="https://theagentcrew.org/blog/how-to-set-up-ai-agent-openclaw-vps/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-xl border border-violet-500/40 bg-violet-500/10 px-5 py-3 text-sm font-semibold text-violet-200 transition hover:bg-violet-500/20"
      >
        Read: Set Up Your First AI Agent in 30 Minutes
      </a>
    </div>

    <p class="mt-5 text-sm text-slate-400">
      Then come back here and choose the paid bundle that removes your next bottleneck.
    </p>
  </section>

  <section id="path-a" class="mt-10">
    <h2 class="text-2xl font-extrabold text-white md:text-3xl">Buy by outcome, not by file list</h2>
    <p class="mt-3 max-w-3xl text-slate-300">
      These are production-tested systems from our live crew. Each one solves a specific operational bottleneck.
    </p>

    <div class="mt-6 grid gap-6 md:grid-cols-2">
      {products.map((product) => (
        <article class="crew-card products-surface flex h-full flex-col rounded-2xl border border-slate-800 p-6 md:p-7">
          <div class="flex items-start justify-between gap-4">
            <h3 class="text-2xl font-extrabold text-white">{product.name}</h3>
            <p class="price-badge">{product.price}</p>
          </div>

          <p class="mt-3 text-base font-semibold text-violet-200">{product.outcome}</p>
          <p class="mt-2 text-slate-300">{product.forLine}</p>

          <ul class="mt-4 space-y-2 text-sm text-slate-300">
            {product.points.map((item) => (
              <li class="flex items-start gap-2">
                <span class="mt-1 text-violet-400">•</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <div class="mt-6">
            <a
              href={product.url}
              target="_blank"
              rel="noopener noreferrer"
              class="cta-primary w-full inline-flex items-center justify-center rounded-xl px-4 py-3.5 text-sm font-semibold text-white"
            >
              Buy on Claw Mart — {product.price}
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .path-block {
    display: block;
    border-radius: 1rem;
    padding: 1.1rem 1rem;
    border: 1px solid rgba(139, 92, 246, 0.35);
    transition: all 0.2s ease;
  }

  .path-label {
    font-size: 1rem;
    font-weight: 800;
    color: #f8fafc;
  }

  .path-copy {
    margin-top: 0.35rem;
    font-size: 0.95rem;
    color: #cbd5e1;
  }

  .path-primary {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.9), rgba(91, 33, 182, 0.92));
    border-color: rgba(167, 139, 250, 0.85);
    box-shadow: 0 8px 26px rgba(76, 29, 149, 0.4);
  }

  .path-secondary {
    background: rgba(124, 58, 237, 0.1);
  }

  .path-block:hover {
    transform: translateY(-1px);
  }

  #path-a,
  #path-b {
    scroll-margin-top: 88px;
  }

  .products-surface {
    background: linear-gradient(140deg, rgba(21, 21, 34, 0.96) 0%, rgba(16, 16, 26, 0.96) 100%);
    overflow: visible;
  }

  .trust-strip {
    max-width: 56rem;
  }

  .trust-pill {
    border: 1px solid rgba(139, 92, 246, 0.35);
    border-radius: 0.75rem;
    padding: 0.55rem 0.75rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: #ddd6fe;
    background: rgba(91, 33, 182, 0.22);
    text-align: center;
  }

  .price-badge {
    border-radius: 0.8rem;
    border: 1px solid rgba(167, 139, 250, 0.65);
    background: rgba(76, 29, 149, 0.34);
    color: #e9d5ff;
    padding: 0.35rem 0.65rem;
    font-size: 1.05rem;
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
  }

  .cta-primary {
    background: linear-gradient(135deg, #8b5cf6, #7c3aed);
    box-shadow: 0 8px 20px rgba(76, 29, 149, 0.35);
    transition: transform 0.15s ease, filter 0.15s ease;
  }

  .cta-primary:hover {
    transform: translateY(-1px);
    filter: brightness(1.04);
  }

  html[data-theme='light'] .products-surface {
    background: linear-gradient(140deg, #ffffff 0%, #f8f5ff 100%);
  }

  html[data-theme='light'] .path-label {
    color: #0f172a;
  }

  html[data-theme='light'] .path-copy {
    color: #334155;
  }

  html[data-theme='light'] .path-primary {
    background: linear-gradient(135deg, #8b5cf6, #7c3aed);
    border-color: #7c3aed;
  }

  html[data-theme='light'] .path-primary .path-label,
  html[data-theme='light'] .path-primary .path-copy {
    color: #ffffff;
  }

  html[data-theme='light'] .path-secondary {
    background: rgba(124, 58, 237, 0.08);
    border-color: rgba(124, 58, 237, 0.35);
  }

  @media (max-width: 640px) {
    .price-badge {
      font-size: 0.95rem;
      padding: 0.3rem 0.55rem;
    }
  }
</style>

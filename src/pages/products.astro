---
import Layout from '../layouts/Layout.astro';

export const prerender = false;

const apiKey = process.env.CLAWMART_API_KEY || import.meta.env.CLAWMART_API_KEY;

interface Listing {
  id?: string | number;
  name?: string;
  title?: string;
  tagline?: string;
  description?: string;
  status?: string;
  price?: number | string;
  amount?: number | string;
  publicUrl?: string;
  public_url?: string;
  slug?: string;
}

const featureMap: Record<string, string[]> = {
  'Wake Up': [
    '6-agent system pre-configured',
    'Runs overnight autonomously',
    'Ready to deploy in minutes',
  ],
  'Revenue GM': [
    'Tracks revenue signals 24/7',
    'Flags opportunities automatically',
    'No manual monitoring needed',
  ],
  'Ship to Production': [
    'Full CI/CD agent workflow',
    'Deploy without touching terminal',
    'Error detection built in',
  ],
  'Coordination Layer': [
    'Multi-agent OS architecture',
    'One agent routes everything',
    'No context drift between agents',
  ],
  'Starter Kit': [
    '4 core config files included',
    'Works with any OpenClaw setup',
    'Zero cost to start',
  ],
};

const toNumber = (value: unknown) => {
  if (typeof value === 'number') return value;
  if (typeof value === 'string') {
    const n = Number(value);
    return Number.isFinite(n) ? n : NaN;
  }
  return NaN;
};

const toDollars = (listing: Listing) => {
  const direct = toNumber(listing.price);
  if (Number.isFinite(direct)) return direct;

  const amount = toNumber(listing.amount);
  if (!Number.isFinite(amount)) return 0;

  return amount > 1000 ? amount / 100 : amount;
};

const getName = (listing: Listing) => listing.name || listing.title || 'Untitled Product';

const fallbackTaglines: Record<string, string> = {
  'Starter Kit': 'The fastest way to see what a real agent setup looks like.',
  'Wake Up': 'Set it before bed. Wake up to results.',
  'Revenue GM': 'Never miss a signal that could turn into money.',
  'Ship to Production': 'From task to deployed. No terminal required.',
  'Coordination Layer': 'One agent routes everything. Zero context drift.',
};

const findProductKey = (name: string, keys: string[]) => {
  const normalizedName = name.toLowerCase();
  return keys.find((key) => normalizedName.includes(key.toLowerCase()));
};

const getTagline = (listing: Listing) => {
  const name = getName(listing);
  const key = findProductKey(name, Object.keys(fallbackTaglines));
  return key ? fallbackTaglines[key] : '';
};

const getUrl = (listing: Listing) => listing.publicUrl || listing.public_url || '#';

const formatPrice = (listing: Listing) => {
  const amount = toDollars(listing);
  if (amount === 0) return 'Free';
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: 0,
    maximumFractionDigits: 2,
  }).format(amount);
};

let listings: Listing[] = [];
let fetchError = '';

if (!apiKey) {
  fetchError = 'CLAWMART_API_KEY is missing on the server.';
} else {
  try {
    const response = await fetch('https://www.shopclawmart.com/api/v1/listings', {
      headers: {
        Authorization: `Bearer ${apiKey}`,
      },
    });

    if (!response.ok) {
      fetchError = `Unable to load products right now (HTTP ${response.status}).`;
    } else {
      const payload = await response.json();
      const data = Array.isArray(payload) ? payload : (payload?.data?.listings ?? payload?.data ?? payload?.listings ?? []);
      const rawListings = Array.isArray(data) ? data : [];

      listings = rawListings.filter((item) => item?.status === 'active');
    }
  } catch {
    fetchError = 'Unable to reach Claw Mart right now. Please try again soon.';
  }
}

const sortedListings = [...listings].sort((a, b) => {
  const aPrice = toDollars(a);
  const bPrice = toDollars(b);
  if (aPrice === 0 && bPrice !== 0) return -1;
  if (aPrice !== 0 && bPrice === 0) return 1;
  return aPrice - bPrice;
});

const genericFeatures = (listing: Listing) => {
  const description = listing.description?.trim();
  const tagline = listing.tagline?.trim();

  const dynamic = [
    description ? description.slice(0, 110) : '',
    tagline ? tagline.slice(0, 110) : '',
  ].filter(Boolean);

  const defaults = [
    'Built by The Agent Crew for practical workflows',
    'Simple setup with immediate value',
    'Works with your current OpenClaw environment',
  ];

  return [...dynamic, ...defaults].slice(0, 3);
};

const getFeatures = (listing: Listing) => {
  const name = getName(listing);
  const key = findProductKey(name, Object.keys(featureMap));
  return key ? featureMap[key] : genericFeatures(listing);
};
---

<Layout
  title="Products | The Agent Crew"
  description="Explore The Agent Crew tool stack available on Claw Mart."
>
  <section class="hero-glow-card space-y-5 rounded-2xl border border-violet-500/30 bg-gradient-to-br from-violet-900/20 to-dark-surface p-10">
    <h1 class="hero-title-gradient max-w-4xl text-4xl font-extrabold leading-tight md:text-6xl">Tools built by agents, for builders</h1>
    <p class="max-w-2xl text-lg text-slate-300">
      Every product we ship comes from running these systems ourselves. No fluff.
    </p>
  </section>

  {fetchError ? (
    <section class="mt-10 rounded-xl border border-amber-300/35 bg-amber-500/10 p-5 text-amber-100">
      {fetchError}
    </section>
  ) : (
    <section class="mt-10">
      <div class="grid gap-6 md:grid-cols-2">
        {sortedListings.map((listing) => {
          const price = toDollars(listing);
          const isFree = price === 0;
          const isLaunchWeek = price === 19;

          return (
            <article class="crew-card flex h-full min-h-[460px] flex-col rounded-2xl border border-slate-800 bg-dark-card p-8 shadow-sm transition">
              <div class="mb-4 flex flex-wrap items-center gap-2">
                {isFree && (
                  <span class="rounded-full border border-violet-500/45 bg-violet-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-violet-200">
                    Start here
                  </span>
                )}
                {isFree && (
                  <span class="rounded-full border border-violet-500/45 bg-violet-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-violet-200">
                    Free
                  </span>
                )}
                {isLaunchWeek && (
                  <span class="rounded-full border border-amber-300/50 bg-amber-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-amber-200">
                    Launch Week
                  </span>
                )}
              </div>

              <h2 class="text-3xl font-extrabold text-white">{getName(listing)}</h2>
              <p class="mt-3 text-5xl font-black text-violet-400">{formatPrice(listing)}</p>
              <p class="mt-3 italic text-slate-300">{getTagline(listing)}</p>

              <ul class="mt-6 space-y-2 text-sm">
                {getFeatures(listing).map((feature) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-1 text-violet-400">•</span>
                    <span class="text-slate-300">{feature}</span>
                  </li>
                ))}
              </ul>

              <a
                href={getUrl(listing)}
                class="mt-7 inline-flex w-full items-center justify-center rounded-xl bg-violet-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-violet-500"
                target="_blank"
                rel="noopener noreferrer"
              >
                {isFree ? 'Start here' : 'Get it on Claw Mart'}
              </a>
            </article>
          );
        })}
      </div>
    </section>
  )}
</Layout>

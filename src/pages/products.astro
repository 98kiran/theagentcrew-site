---
import Layout from '../layouts/Layout.astro';

export const prerender = false;

const products = [
  {
    name: 'The Coordination Layer',
    price: '$49',
    forLine: "For teams running 2+ agents that keep colliding on the same work.",
    items: [
      'Active tasks schema as the single source of truth',
      'Communication protocol with clear agent handoff rules',
      'Watchdog cron auto retry, agent rules template, and install setup script',
    ],
    url: 'https://www.shopclawmart.com/listings/the-coordination-layer-multi-agent-os-v2-0-ec71308a?utm_source=theagentcrew&utm_medium=products_path_a',
  },
  {
    name: 'Wake Up to Finished Work',
    price: '$49',
    forLine: 'For OpenClaw users who want a full overnight team already configured.',
    items: [
      'Identity and role templates for all 6 agents',
      'Overnight heartbeat task loop for each role',
      'Cron schedule for 3am to 6am runs with memory architecture for shared context',
    ],
    url: 'https://www.shopclawmart.com/listings/wake-up-to-finished-work-6-agent-ai-team-system-v2-0-f4a2cb6b?utm_source=theagentcrew&utm_medium=products_path_a',
  },
  {
    name: 'Ship to Production',
    price: '$29',
    forLine: 'For builders who want agents to run the deploy path safely.',
    items: [
      'Staging workflow from branch to review to merge',
      'SamDev rules with a mandatory pre ship checklist',
      'Deploy script plus PM2 and nginx config templates',
    ],
    url: 'https://www.shopclawmart.com/listings/ship-to-production-ai-crew-ops-stack-v2-0-2a5e5209?utm_source=theagentcrew&utm_medium=products_path_a',
  },
  {
    name: 'Revenue GM',
    price: '$19',
    forLine: 'For founders who want a research to content engine that keeps moving.',
    items: [
      'Scout and Quill agent configs with handoff flow',
      'Content brief templates and publishing workflow',
      'Claw Mart listing automation scripts',
    ],
    url: 'https://www.shopclawmart.com/listings/your-ai-revenue-gm-never-miss-a-money-signal-v2-0-0c4a036e?utm_source=theagentcrew&utm_medium=products_path_a',
  },
];
---

<Layout
  title="Products | The Agent Crew"
  description="Get the exact systems we run for OpenClaw teams. Choose your path and start today."
>
  <section class="hero-glow-card space-y-5 rounded-2xl border border-violet-500/30 bg-gradient-to-br from-violet-900/20 to-dark-surface p-8 md:p-10">
    <h1 class="hero-title-gradient max-w-4xl text-3xl font-extrabold leading-tight md:text-5xl">
      You saw the overnight crew. Here's how to get one.
    </h1>
    <p class="max-w-3xl text-base text-slate-300 md:text-lg">
      Pick where you're starting from and we'll show you exactly what to do next.
    </p>

    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <a href="#path-b" class="path-block path-primary">
        <p class="path-label">I'm starting from scratch</p>
        <p class="path-copy">Show me how to set this up.</p>
      </a>

      <a href="#path-a" class="path-block path-secondary">
        <p class="path-label">I already use OpenClaw</p>
        <p class="path-copy">Show me the products.</p>
      </a>
    </div>
  </section>

  <section id="path-b" class="products-surface mt-10 rounded-2xl border border-violet-500/30 p-6 md:p-8">
    <h2 class="text-2xl font-extrabold text-white md:text-3xl">New to this? Start here.</h2>
    <p class="mt-3 max-w-3xl text-slate-300">
      Without this kit, your agent runs but has no identity, no memory, and no initiative. We put together a free starter pack so it wakes up every session knowing who it is, what it's working on, and what to check next.
    </p>

    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <a
        href="https://www.shopclawmart.com/listings/free-agent-starter-kit-soul-md-templates-2d7777e7?utm_source=theagentcrew&utm_medium=products_path_b"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-xl bg-violet-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-violet-500"
      >
        Grab Your Free Starter Kit
      </a>
      <a
        href="https://theagentcrew.org/blog/how-to-set-up-ai-agent-openclaw-vps/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-xl border border-violet-500/40 bg-violet-500/10 px-5 py-3 text-sm font-semibold text-violet-200 transition hover:bg-violet-500/20"
      >
        Read the Setup Guide
      </a>
    </div>

    <p class="mt-5 text-sm text-slate-400">
      After you go through those two links, pick the product that matches what you want to run next.
    </p>
  </section>

  <section id="path-a" class="mt-10">
    <h2 class="text-2xl font-extrabold text-white md:text-3xl">The full product lineup</h2>
    <p class="mt-3 max-w-3xl text-slate-300">
      We run these on a live 6 agent team every day. These are the exact systems we built for that workflow.
    </p>

    <div class="mt-6 grid gap-6 md:grid-cols-2">
      {products.map((product) => (
        <article class="crew-card products-surface flex h-full flex-col rounded-2xl border border-slate-800 p-6 md:p-7">
          <h3 class="text-2xl font-extrabold text-white">{product.name}</h3>
          <p class="mt-2 text-slate-300">{product.forLine}</p>

          <h4 class="mt-5 text-sm font-semibold uppercase tracking-wide text-violet-200">What's inside</h4>
          <ul class="mt-3 space-y-2 text-sm text-slate-300">
            {product.items.map((item) => (
              <li class="flex items-start gap-2">
                <span class="mt-1 text-violet-400">•</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <div class="mt-6 flex items-center justify-between gap-4">
            <p class="text-2xl font-bold text-violet-300">{product.price}</p>
            <a
              href={product.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-xl bg-violet-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-violet-500"
            >
              Get it on Claw Mart
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .path-block {
    display: block;
    border-radius: 1rem;
    padding: 1.1rem 1rem;
    border: 1px solid rgba(139, 92, 246, 0.35);
    transition: all 0.2s ease;
  }

  .path-label {
    font-size: 1rem;
    font-weight: 800;
    color: #f8fafc;
  }

  .path-copy {
    margin-top: 0.35rem;
    font-size: 0.95rem;
    color: #cbd5e1;
  }

  .path-primary {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.85), rgba(91, 33, 182, 0.88));
    border-color: rgba(167, 139, 250, 0.8);
    box-shadow: 0 6px 20px rgba(76, 29, 149, 0.35);
  }

  .path-secondary {
    background: rgba(124, 58, 237, 0.1);
  }

  .path-block:hover {
    transform: translateY(-1px);
  }

  .products-surface {
    background: linear-gradient(140deg, rgba(21, 21, 34, 0.96) 0%, rgba(16, 16, 26, 0.96) 100%);
  }

  html[data-theme='light'] .products-surface {
    background: linear-gradient(140deg, #ffffff 0%, #f8f5ff 100%);
  }

  html[data-theme='light'] .path-label {
    color: #0f172a;
  }

  html[data-theme='light'] .path-copy {
    color: #334155;
  }

  html[data-theme='light'] .path-primary {
    background: linear-gradient(135deg, #8b5cf6, #7c3aed);
    border-color: #7c3aed;
  }

  html[data-theme='light'] .path-primary .path-label,
  html[data-theme='light'] .path-primary .path-copy {
    color: #ffffff;
  }

  html[data-theme='light'] .path-secondary {
    background: rgba(124, 58, 237, 0.08);
    border-color: rgba(124, 58, 237, 0.35);
  }
</style>

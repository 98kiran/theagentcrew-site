---
import Layout from '../layouts/Layout.astro';

export const prerender = false;

const apiKey = import.meta.env.CLAWMART_API_KEY || process.env.CLAWMART_API_KEY;

interface Listing {
  id?: string | number;
  name?: string;
  title?: string;
  tagline?: string;
  description?: string;
  status?: string;
  price?: number | string;
  amount?: number | string;
  publicUrl?: string;
  public_url?: string;
  slug?: string;
}

const featureMap: Record<string, string[]> = {
  'Wake Up to Finished Work': [
    '6-agent system pre-configured',
    'Runs overnight autonomously',
    'Ready to deploy in minutes',
  ],
  'Your AI Revenue GM': [
    'Tracks revenue signals 24/7',
    'Flags opportunities automatically',
    'No manual monitoring needed',
  ],
  'Ship to Production': [
    'Full CI/CD agent workflow',
    'Deploy without touching terminal',
    'Error detection built in',
  ],
  'The Coordination Layer': [
    'Multi-agent OS architecture',
    'One agent routes everything',
    'No context drift between agents',
  ],
  'Free Multi-Agent Starter Kit': [
    '4 core config files included',
    'Works with any OpenClaw setup',
    'Zero cost to start',
  ],
};

const toNumber = (value: unknown) => {
  if (typeof value === 'number') return value;
  if (typeof value === 'string') {
    const n = Number(value);
    return Number.isFinite(n) ? n : NaN;
  }
  return NaN;
};

const toDollars = (listing: Listing) => {
  const direct = toNumber(listing.price);
  if (Number.isFinite(direct)) return direct;

  const amount = toNumber(listing.amount);
  if (!Number.isFinite(amount)) return 0;

  return amount > 1000 ? amount / 100 : amount;
};

const getName = (listing: Listing) => listing.name || listing.title || 'Untitled Product';

const fallbackTaglines: Record<string, string> = {
  'Free Multi-Agent Starter Kit': 'The fastest way to see what a real agent setup looks like.',
  'Wake Up to Finished Work': 'Set it before bed. Wake up to results.',
  'Your AI Revenue GM': 'Never miss a signal that could turn into money.',
  'Ship to Production': 'From task to deployed. No terminal required.',
  'The Coordination Layer': 'One agent routes everything. Zero context drift.',
};

const getTagline = (listing: Listing) => {
  const name = getName(listing);
  const rawTagline = (listing.tagline || listing.description || '').trim();
  const isGeneric = rawTagline.toLowerCase() === 'built by the agent crew' || rawTagline.toLowerCase() === 'built by the agent crew.';

  if (!rawTagline || isGeneric) {
    return fallbackTaglines[name] || 'Built by The Agent Crew.';
  }

  return rawTagline;
};

const getUrl = (listing: Listing) => listing.publicUrl || listing.public_url || '#';

const formatPrice = (listing: Listing) => {
  const amount = toDollars(listing);
  if (amount === 0) return 'Free';
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: 0,
    maximumFractionDigits: 2,
  }).format(amount);
};

let listings: Listing[] = [];
let fetchError = '';

if (!apiKey) {
  fetchError = 'CLAWMART_API_KEY is missing on the server.';
} else {
  try {
    const response = await fetch('https://www.shopclawmart.com/api/v1/listings', {
      headers: {
        Authorization: `Bearer ${apiKey}`,
      },
    });

    if (!response.ok) {
      fetchError = `Unable to load products right now (HTTP ${response.status}).`;
    } else {
      const payload = await response.json();
      const data = Array.isArray(payload) ? payload : (payload?.data?.listings ?? payload?.data ?? payload?.listings ?? []);
      const rawListings = Array.isArray(data) ? data : [];

      listings = rawListings.filter((item: Listing) => item?.status === 'active');
    }
  } catch {
    fetchError = 'Unable to reach Claw Mart right now. Please try again soon.';
  }
}

const freeListing = listings.find((listing) => toDollars(listing) === 0);
const paidListings = listings
  .filter((listing) => toDollars(listing) > 0)
  .sort((a, b) => toDollars(a) - toDollars(b));

const getFeatures = (listing: Listing) => featureMap[getName(listing)] ?? ['Built by agents for real workflows', 'Clear setup path included', 'Made for daily shipping'];
---

<Layout
  title="Products | The Agent Crew"
  description="Explore The Agent Crew tool stack available on Claw Mart."
>
  <section class="hero-glow-card space-y-5 rounded-2xl border border-violet-500/30 bg-gradient-to-br from-violet-900/20 to-dark-surface p-10">
    <h1 class="hero-title-gradient max-w-4xl text-4xl font-extrabold leading-tight md:text-6xl">Tools built by agents, for builders</h1>
    <p class="max-w-2xl text-lg text-slate-300">
      Every product we ship comes from running these systems ourselves. No fluff.
    </p>
  </section>

  {fetchError ? (
    <section class="mt-10 rounded-xl border border-amber-300/35 bg-amber-500/10 p-5 text-amber-100">
      {fetchError}
    </section>
  ) : (
    <section class="mt-10 space-y-8">
      {freeListing && (
        <article class="rounded-2xl border border-violet-500/35 bg-dark-card p-8 shadow-sm">
          <div class="mb-4 flex flex-wrap items-center gap-2">
            <span class="rounded-full border border-violet-500/45 bg-violet-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-violet-600 dark:text-violet-300">
              Start here
            </span>
            <span class="rounded-full border border-violet-500/45 bg-violet-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-violet-600 dark:text-violet-300">
              Free
            </span>
          </div>

          <h2 class="text-3xl font-extrabold text-white">{getName(freeListing)}</h2>
          <p class="mt-3 text-5xl font-black text-violet-600 dark:text-violet-300">{formatPrice(freeListing)}</p>
          <p class="mt-3 italic text-slate-600 dark:text-slate-300">{getTagline(freeListing)}</p>

          <ul class="mt-6 space-y-2 text-sm text-slate-700 dark:text-slate-300">
            {getFeatures(freeListing).map((feature) => (
              <li class="flex items-start gap-2">
                <span class="mt-1 text-violet-500">•</span>
                <span class="text-slate-700 dark:text-slate-300">{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href={getUrl(freeListing)}
            class="mt-7 inline-flex w-full items-center justify-center rounded-xl bg-violet-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-violet-500"
            target="_blank"
            rel="noopener noreferrer"
          >
            Get it on Claw Mart
          </a>
        </article>
      )}

      <div class="grid gap-6 md:grid-cols-2">
        {paidListings.map((listing) => {
          const price = toDollars(listing);
          const isLaunchWeek = price === 19;

          return (
            <article class="flex h-full flex-col rounded-2xl border border-slate-800 bg-dark-card p-8 shadow-sm">
              <div class="mb-4 flex flex-wrap items-center gap-2">
                {isLaunchWeek && (
                  <span class="rounded-full border border-amber-300/50 bg-amber-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-amber-700 dark:text-amber-200">
                    Launch Week
                  </span>
                )}
              </div>

              <h2 class="text-3xl font-extrabold text-white">{getName(listing)}</h2>
              <p class="mt-3 text-5xl font-black text-violet-600 dark:text-violet-300">{formatPrice(listing)}</p>
              <p class="mt-3 italic text-slate-600 dark:text-slate-300">{getTagline(listing)}</p>

              <ul class="mt-6 space-y-2 text-sm text-slate-700 dark:text-slate-300">
                {getFeatures(listing).map((feature) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-1 text-violet-500">•</span>
                    <span class="text-slate-700 dark:text-slate-300">{feature}</span>
                  </li>
                ))}
              </ul>

              <a
                href={getUrl(listing)}
                class="mt-7 inline-flex w-full items-center justify-center rounded-xl bg-violet-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-violet-500"
                target="_blank"
                rel="noopener noreferrer"
              >
                Get it on Claw Mart
              </a>
            </article>
          );
        })}
      </div>
    </section>
  )}
</Layout>
